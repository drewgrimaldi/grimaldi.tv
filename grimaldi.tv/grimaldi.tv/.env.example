# Supabase - grimaldi.tv's own database (Settings -> API in that Supabase project)
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase - studio.grimaldi.tv's database (a SEPARATE Supabase project, used
# only to read published blog posts). Get from Settings -> API on that project.
VITE_STUDIO_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_STUDIO_SUPABASE_ANON_KEY=your-studio-anon-public-key

# Used only by Cloudflare Pages Functions (server-side, never exposed to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
STUDIO_SUPABASE_URL=https://xxxxxxxx.supabase.co
STUDIO_SUPABASE_ANON_KEY=your-studio-anon-public-key
RESEND_API_KEY=your-resend-api-key
ADMIN_NOTIFY_EMAIL=drew@grimaldi.tv
